# syntax=docker/dockerfile:1
# HyperFrames（超框架）渲染需要 FFmpeg + Headless Chrome 依賴

FROM node:22-bookworm-slim AS base
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    ca-certificates \
    fonts-noto-cjk \
    libnss3 \
    libatk-bridge2.0-0 \
    libdrm2 \
    libxkbcommon0 \
    libgbm1 \
    libasound2 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libpango-1.0-0 \
    libcairo2 \
    libgtk-3-0 \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable
WORKDIR /app

FROM base AS deps
# 雲端建置常注入 NODE_ENV=production，會略過 devDependencies（含 turbo）
ENV NODE_ENV=development
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/worker/package.json apps/worker/
COPY packages/composition/package.json packages/composition/
COPY packages/core/package.json packages/core/
COPY packages/db/package.json packages/db/
COPY packages/hf-bridge/package.json packages/hf-bridge/
COPY packages/llm/package.json packages/llm/
COPY packages/shared/package.json packages/shared/
COPY packages/tts/package.json packages/tts/
COPY packages/wvp-bridge/package.json packages/wvp-bridge/
COPY packages/presentation/package.json packages/presentation/
COPY packages/visual-config/package.json packages/visual-config/
RUN pnpm install --frozen-lockfile

FROM deps AS builder
ENV NODE_ENV=development
COPY . .
RUN pnpm turbo build --filter=@courseflow/worker...

FROM base AS runner
ENV NODE_ENV=production
ENV COURSEFLOW_PRESENTATION_ROOT=/tmp/cf-presentations
WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
# pnpm workspace：需保留 apps/worker/node_modules 符號連結，否則執行期找不到 dotenv 等依賴
COPY --from=builder /app/apps/worker ./apps/worker
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=builder /app/pnpm-workspace.yaml ./pnpm-workspace.yaml

# WVP MP4：Playwright Chromium（與 ffmpeg 搭配）
RUN npx --yes playwright@1.52.0 install chromium

CMD ["node", "apps/worker/dist/index.js"]
