# CourseFlow v2 — 請複製到 apps/web/.env.local 與 apps/worker/.env
#
# 模式 A（建議本機）：新建 v2 專用 Supabase / Redis → 見 docs/INFRA-ISOLATION.md
# 模式 B（正式 cutover）：沿用既有 courseflow-web 的 Supabase / Redis
#   → 見 docs/DEPLOY-CUTOVER-courseflow-web.md，並在 Supabase 跑 v2 migrations

COURSEFLOW_EDITION=v2

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-V2-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

REDIS_URL=redis://127.0.0.1:6379

# 與 v1 分開的加密金鑰（32+ 字元隨機字串）
API_KEY_ENCRYPTION_SECRET=

# 本機未跑 Redis / Worker 時請設為 1，語音與 WVP MP4 會在 Web 行程內直接執行
COURSEFLOW_INLINE_JOBS=1

# WVP MP4 內嵌錄製需：npx playwright install chromium，以及 PATH 上的 ffmpeg
