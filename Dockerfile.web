# syntax=docker/dockerfile:1

FROM node:22-bookworm-slim AS base
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable
WORKDIR /app

FROM base AS deps
# 雲端建置常注入 NODE_ENV=production，會略過 devDependencies（含 turbo）
ENV NODE_ENV=development
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json apps/web/
COPY apps/worker/package.json apps/worker/
COPY packages/composition/package.json packages/composition/
COPY packages/core/package.json packages/core/
COPY packages/db/package.json packages/db/
COPY packages/hf-bridge/package.json packages/hf-bridge/
COPY packages/llm/package.json packages/llm/
COPY packages/player/package.json packages/player/
COPY packages/shared/package.json packages/shared/
COPY packages/tts/package.json packages/tts/
COPY packages/craft-agent/package.json packages/craft-agent/
COPY packages/presentation/package.json packages/presentation/
COPY packages/visual-config/package.json packages/visual-config/
COPY packages/explain-animation/package.json packages/explain-animation/
COPY packages/wvp-bridge/package.json packages/wvp-bridge/
RUN pnpm install --frozen-lockfile

FROM deps AS builder
ENV NODE_ENV=development
# Next.js 會把 NEXT_PUBLIC_* 編進瀏覽器 bundle，建置階段必須有值（Render 會把服務 env 當 build-arg 傳入）
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}
COPY . .
RUN node scripts/build-bananax-catalog.mjs
RUN pnpm turbo build --filter=@courseflow/web...

FROM base AS runner
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
# Presentation 工作目錄：非 root user 可寫入的 /tmp；build 產物上傳到 Supabase Storage
ENV COURSEFLOW_PRESENTATION_ROOT=/tmp/cf-presentations
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 --home /home/nextjs --ingroup nodejs nextjs \
  && mkdir -p /home/nextjs /tmp/cf-presentations /tmp/.npm-cache \
  && chown -R nextjs:nodejs /home/nextjs /tmp/cf-presentations /tmp/.npm-cache

ENV HOME=/home/nextjs
ENV NPM_CONFIG_CACHE=/tmp/.npm-cache

COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
# WVP 模板／主題：scaffold 以 fs 讀取 vendor，standalone trace 不會自動打包
COPY --from=builder --chown=nextjs:nodejs \
  /app/packages/wvp-bridge/vendor/web-video-presentation \
  ./packages/wvp-bridge/vendor/web-video-presentation

USER nextjs
EXPOSE 3000
ENV PORT=3000
CMD ["node", "apps/web/server.js"]
