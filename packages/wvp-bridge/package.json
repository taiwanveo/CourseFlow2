{
  "name": "@courseflow/wvp-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/copy-themes.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@courseflow/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
