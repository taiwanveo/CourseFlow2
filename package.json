{
  "name": "courseflow-v2",
  "private": true,
  "scripts": {
    "build:packages": "turbo build --filter=./packages/*",
    "dev": "turbo dev --filter=@courseflow/web",
    "dev:worker": "pnpm --filter @courseflow/worker dev",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "sync-wvp": "node scripts/sync-wvp-skill.mjs",
    "bananax:catalog": "node scripts/build-bananax-catalog.mjs",
    "render:cutover": "node scripts/render-cutover.mjs",
    "bananax:catalog:json": "node scripts/build-bananax-catalog.mjs --skip-download",
    "playwright:install": "pnpm --filter @courseflow/presentation exec playwright install chromium"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  }
}
